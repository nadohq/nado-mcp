# Required: Chain environment (inkMainnet or inkTestnet)
CHAIN_ENV=inkMainnet

# Optional: Custom RPC URL (overrides default chain RPC)
RPC_URL=

# Optional: Private key for write operations (Phase 2)
# When absent, the server runs in read-only mode
PRIVATE_KEY=

# FRANK: is it possible to use other subaccounts? is this just the default?
# Optional: Default subaccount name
SUBACCOUNT_NAME=default
