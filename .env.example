# ---------------------------------------------------------------
# Prefer setting these in your MCP client config instead of here.
# For example, in .cursor/mcp.json → "env": { "CHAIN_ENV": "inkMainnet", "PRIVATE_KEY": "0x..." }
# This .env file is only used as a fallback for local development.
# ---------------------------------------------------------------

# Required: Chain environment (inkMainnet or inkTestnet)
CHAIN_ENV=inkMainnet

# Optional: Custom RPC URL (overrides default chain RPC)
RPC_URL=

# Optional: Private key for write operations
# When absent, the server runs in read-only mode
PRIVATE_KEY=

# Optional: Default subaccount name
SUBACCOUNT_NAME=default
