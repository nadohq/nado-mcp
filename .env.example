# ---------------------------------------------------------------
# Prefer setting these in your MCP client config instead of here.
# For example, in .cursor/mcp.json → "env": { "DATA_ENV": "nadoMainnet", "PRIVATE_KEY": "0x..." }
# This .env file is only used as a fallback for local development.
# ---------------------------------------------------------------

# Required: Data environment (nadoMainnet or nadoTestnet)
DATA_ENV=nadoMainnet

# Optional: Custom RPC URL (overrides default chain RPC)
RPC_URL=

# Optional: Private key for write operations (also derives the default wallet address)
# When absent, the server runs in read-only mode
PRIVATE_KEY=

# Optional: Explicit wallet address that owns the subaccount
# Use this when using a linked signer (PRIVATE_KEY is the signer, SUBACCOUNT_OWNER is the main wallet)
# When omitted, the address is derived from PRIVATE_KEY
SUBACCOUNT_OWNER=

# Optional: Default subaccount name
SUBACCOUNT_NAME=default
